DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-this-for-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Console backend for the class demo.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=groupf-demo@example.com

